Host localhost 127.*
    Hostname 127.0.0.1
    User testuser
    IdentityFile testdata/id_rsa
    Port 22

Host Connect*
    Port 1234

Host proxy-target
    Hostname %h.example.com
    Port 2222
    User proxyuser
    ProxyJump jumpbox
    StrictHostKeyChecking no

Host jumpbox
    Hostname jump.example.com
    Port 22
    User jumpuser
    StrictHostKeyChecking no

Host *
    User testuser2
